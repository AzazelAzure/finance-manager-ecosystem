# Copy to `.env` for docker-compose and local tooling (never commit `.env`).
# DB_NAME=finance_db
# DB_USER=finance_user
# DB_PASSWORD=change_me
# SECRET_KEY=change_me

# Local VPS ops helpers (`scripts/ops/vps_state.sh`, `scripts/ops/sprint_verify.sh`).
# Keep the same raw IP in GitHub repository secret `VPS_ORIGIN_IP`.
# Local scripts derive FM_SPRINT_SSH=dev@$VPS_ORIGIN_IP unless you override it.
# VPS_ORIGIN_IP=203.0.113.10
# FM_SPRINT_SSH=dev@203.0.113.10
# FM_SPRINT_REMOTE_ROOT=/home/dev/finance_manager
# VPS_STATE_SSH_TIMEOUT=20
# VPS_STATE_EXPECTED=7
