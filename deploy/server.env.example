# Finance Manager server environment (example only — copy and fill secrets locally).
# Suggested workflow: scripts/server/bootstrap_env.sh --from-example
# Committing real passwords, keys, or tokens is forbidden.
# Default local target: .secrets/server.env (ignored by git).
#
# For docker compose, mirror variable names expected by compose and Django settings.

# --- Django ---
SECRET_KEY=CHANGE_ME_generate_a_long_random_string
DEBUG=False

# --- Database ---
DB_NAME=finance_db
DB_USER=finance_user
DB_PASSWORD=CHANGE_ME_db_password
DB_HOST=db
DB_PORT=5432

# Comma-separated; include your public hostname and localhost for probes.
# Blue/green compose: add api-blue,api-green (internal health checks; omitting yields 400 DisallowedHost).
# Staging API vhost: api-jsdevtesting.yourdomain (see deploy/BLUEGREEN_SWITCHOVER.md).
ALLOWED_HOSTS=api.example.com,localhost,127.0.0.1,api-blue,api-green,api-jsdevtesting.thehivemanager.com

# HTTPS origins for CSRF (include scheme)
CSRF_TRUSTED_ORIGINS=https://api.example.com,http://localhost:8000

# --- Service URLs ---
API_BASE_URL=https://api.example.com

# --- Redis (required for Celery + observability cache) ---
REDIS_URL=redis://redis:6379/0
# Current beta decision: Redis is required for shared cache/session posture during blue/green cutover.
# If Redis is unavailable, deploy/smoke should be treated as failed.

# --- Celery observability (T02–T04) ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
LOG_IP_HASH_SALT=CHANGE_ME_generate_random_hex
ANALYTICS_LOG_DIR=/var/log/fm_api/analytics
SEC_THRESHOLD_AUTH_FAILURE=10
SEC_THRESHOLD_INVALID_ENDPOINT=20
SEC_THRESHOLD_5XX_RATE_PCT=5
# Set to 1 ONLY when the API is behind a trusted proxy (Cloudflare/Nginx) that
# overwrites client-IP headers; otherwise forwarded headers are ignored and
# REMOTE_ADDR is used so per-IP security counters cannot be spoofed.
OBSERVABILITY_TRUST_PROXY_IP=0

# --- Blue/Green rollout (inactive color not served by proxy after T03+) ---
FM_ACTIVE_COLOR=blue
FM_API_IMAGE=docker.io/your-registry/finance-manager-api:latest

# --- Operator notify / support intake (F-012 / F-014) ---
BUG_REPORT_TO_EMAIL=operator@example.com
SUPPORT_DIGEST_TO_EMAIL=operator@example.com
OPERATOR_NOTIFY_EMAIL=operator@example.com
BETA_FEATURE_REQUESTS_ENABLED=True
DAU_ALERT_THRESHOLDS=10,50,100

# Proton Bridge SMTP (VPS) — never commit real credentials
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=127.0.0.1
EMAIL_PORT=1025
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@thehivemanager.com

