# HitM calendar + task snapshot (generated locally; personal — refresh with scripts/schedule_agent_sync.sh)
governance/HITM_SCHEDULE_SNAPSHOT.md

# Local secrets (never commit)
.env
.env.*
!.env.example
.secrets/
deploy/server.env
deploy/*.env
# Ad-hoc secret handoff files (e.g. SMTP token drops)
*.secret
smtp.secret

# Editor / tool-only ignore files (machine-local, not shared)
.cursorignore
.antigravityignore

# Obsidian vault config (machine-local workspace state; not shared)
# design_docs/.obsidian is tracked inside the design_docs submodule separately
.obsidian/

# Cursor hooks local runtime state (agent transcript / continual-learning; not shared)
.cursor/hooks/state/

# Python virtual environments
**/.venv/
**/venv/
**/hive_venv/
.venv/
venv/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
*.log
logs/

# Headless Slack bridge runtime (local machine)
.cursor_slack_agent_state.json
.cursor_pr_status_log.jsonl

# Local database / dumps
*.sqlite3
db.sqlite3
migration_dump*.json

# OS / editor
.DS_Store
*~

# Node (if generated at repo root)
node_modules/

# Local build / release artifacts at repo root (runtime bundles, ad-hoc dist)
dist/

# Local TLS certificates and keys (generate per dev machine; never commit private material)
proxy/certs/*.pem

# Business strategy and planning docs (private; scrubbed from history)
strategy/
plans/
.fm_workspace.conf
