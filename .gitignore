# Local secrets (never commit)
.env
.env.*
!.env.example
.secrets/
deploy/server.env
deploy/*.env

# Editor / tool-only ignore files (machine-local, not shared)
.cursorignore
.antigravityignore

# Python virtual environments
**/.venv/
**/venv/
**/hive_venv/
.venv/
venv/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
*.log
logs/

# Headless Slack bridge runtime (local machine)
.cursor_slack_agent_state.json
.cursor_pr_status_log.jsonl

# Local database / dumps
*.sqlite3
db.sqlite3
migration_dump*.json

# OS / editor
.DS_Store
*~

# Node (if generated at repo root)
node_modules/

# Local TLS certificates and keys (generate per dev machine; never commit private material)
proxy/certs/*.pem
